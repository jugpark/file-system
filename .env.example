# ─── 기본 ───────────────────────────────────────────
# 프로덕션에서는 실제 도메인 (OAuth redirect의 기준 URL)
BASE_URL=http://localhost:5173
PORT=3000
# 32바이트 이상 랜덤 문자열 (openssl rand -base64 32)
SESSION_SECRET=change-me-in-production

# 실제 파일이 저장되는 루트 (프로덕션: NAS 마운트 경로)
STORAGE_ROOT=./data/storage
DATABASE_PATH=./data/app.db
MAX_UPLOAD_MB=2048

# ─── Discord ────────────────────────────────────────
# 비워두면 개발용 가짜 로그인(dev auth)으로 동작한다 (프로덕션에서는 필수)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ─── dev auth 모드 전용 ─────────────────────────────
DEV_USER_ID=100000000000000001
DEV_USERNAME=dev
DEV_ROLES=design
