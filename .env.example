# ─── 기본 ───────────────────────────────────────────
# 프로덕션에서는 실제 도메인 (OAuth redirect의 기준 URL)
BASE_URL=http://localhost:5173
PORT=3000
# 32바이트 이상 랜덤 문자열 (openssl rand -base64 32)
SESSION_SECRET=change-me-in-production

# 실제 파일이 저장되는 루트 (프로덕션: NAS 마운트 경로)
STORAGE_ROOT=./data/storage
DATABASE_PATH=./data/app.db
MAX_UPLOAD_MB=2048
# inotify가 전달되지 않는 마운트(WSL 9p/drvfs, 일부 NFS/SMB)에서만 true
WATCH_POLLING=false
# 검색 인덱스 주기 전체 재스캔(분), 워처 안전망. 0=끔
INDEX_RESCAN_MIN=10
# 휴지통 보존 일수 (초과분 매일 영구 삭제). 0=자동 비우기 끔
TRASH_RETENTION_DAYS=30

# ─── 확장 (R1/R2) ───────────────────────────────────
# 이 Discord role 보유자는 admin (전 경로 접근·관리 페이지). 비우면 admin 없음
ADMIN_ROLE_ID=
# 설정 시 공유 폴더 업로드/삭제·디스크 경고를 이 채널 웹훅으로 알림
DISCORD_WEBHOOK_URL=

# ─── Discord ────────────────────────────────────────
# 비워두면 개발용 가짜 로그인(dev auth)으로 동작한다 (프로덕션에서는 필수)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ─── dev auth 모드 전용 ─────────────────────────────
DEV_USER_ID=100000000000000001
DEV_USERNAME=dev
DEV_ROLES=design
