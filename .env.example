# ─── 기본 ───────────────────────────────────────────
# 프로덕션에서는 실제 도메인 (OAuth redirect의 기준 URL)
BASE_URL=http://localhost:5173
PORT=3000
# 32바이트 이상 랜덤 문자열 (openssl rand -base64 32)
SESSION_SECRET=change-me-in-production

# 실제 파일이 저장되는 루트 (프로덕션: NAS 마운트 경로)
STORAGE_ROOT=./data/storage
DATABASE_PATH=./data/app.db
MAX_UPLOAD_MB=2048
# 바인딩 주소 — 본인 PC 전용 테스트면 127.0.0.1 (기본 0.0.0.0)
HOST=0.0.0.0
# inotify가 전달되지 않는 마운트(WSL 9p/drvfs, 일부 NFS/SMB)에서만 true
WATCH_POLLING=false
# 검색 인덱스 주기 전체 재스캔(분), 워처 안전망. 0=끔
INDEX_RESCAN_MIN=10
# 드라이브 루트 같은 초대형 트리를 STORAGE_ROOT로 잡을 때 true — 검색/최근파일만 꺼짐
INDEX_DISABLED=false
# 스테이징/휴지통/버전 보관소 위치 재정의 (기본: STORAGE_ROOT 안의 .tmp/.trash/.versions).
# 반드시 STORAGE_ROOT와 같은 볼륨이어야 함 (rename 원자성)
#TMP_DIR=
#TRASH_DIR=
#VERSIONS_DIR=
# 휴지통 보존 일수 (초과분 매일 영구 삭제). 0=자동 비우기 끔
TRASH_RETENTION_DAYS=30

# ─── 확장 (R1/R2) ───────────────────────────────────
# 이 Discord role 보유자는 admin (전 경로 접근·관리 페이지). 비우면 admin 없음
ADMIN_ROLE_ID=
# 설정 시 공유 폴더 업로드/삭제·디스크 경고를 이 채널 웹훅으로 알림
DISCORD_WEBHOOK_URL=

# ─── Discord ────────────────────────────────────────
# 비워두면 개발용 가짜 로그인(dev auth)으로 동작한다 (프로덕션에서는 필수)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ─── dev auth 모드 전용 ─────────────────────────────
DEV_USER_ID=100000000000000001
DEV_USERNAME=dev
DEV_ROLES=design

# 업로드 바이러스 스캔 (선택) — compose의 clamav 서비스 사용 시
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310
# SCAN_FAIL_CLOSED=true   # 무인증(파일요청) 업로드는 스캐너 장애 시 차단

# 주간 활동 다이제스트 (웹훅 설정 시) — 요일 0=일~6=토, 끄려면 -1
# DIGEST_DAY=1
# DIGEST_HOUR=9
